generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ===================================
// ENUMS
// ===================================
enum Role {
  user
  admin
}

enum OrderStatus {
  pending // Очікує обробки
  processing // В обробці (може змінюватись адміном)
  shipped // Відправлено
  delivered // Доставлено
  canceled // Скасовано
}

enum PaymentStatus {
  pending // Очікує оплати
  paid // Оплачено
  failed // Невдала оплата
  refunded // Повернення коштів
}

// ===================================
// АВТОРИЗАЦІЯ (NEXTAUTH)
// ===================================
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // ✅ ВИПРАВЛЕНО: ДОДАНО поле password для користувачів, які реєструються за паролем (якщо не використовують OAuth)
  password      String?
  // ✅ ВИПРАВЛЕНО: Використовуємо Enum для ролі
  role          Role      @default(user)
  accounts      Account[]
  sessions      Session[]
  Cart          Cart[]
  Order         Order[]

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

// ===================================
// ПРОДУКТИ
// ===================================
model Product {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String @unique
  description String
  imageUrl    String

  brand    String?
  category String?
  price    Int
  isNew    Boolean @default(true)

  // ✅ ДОДАЄМО
  gender String? // "men" | "women" | "unisex"
  sizes  String[] // ["XS","S","M","L"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  CartItem  CartItem[]
  OrderItem OrderItem[]

  @@map("products") // ✅ ОЦЕ ГОЛОВНЕ
}

// ===================================
// КОШИК
// ===================================
model Cart {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
  userId    String?    @db.ObjectId
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  cartId    String   @db.ObjectId
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, cartId])
  @@map("cartitems")
}

// ===================================
// ЗАМОВЛЕННЯ
// ===================================
model Order {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  // ✅ ВИПРАВЛЕНО: Використовуємо Enum для статусу замовлення
  status        OrderStatus   @default(pending)
  // ✅ ДОДАНО: Окремий Enum для статусу оплати
  paymentStatus PaymentStatus @default(pending)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     OrderItem[]
  userId    String?     @db.ObjectId
  user      User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Дані отримувача
  name     String?
  email    String?
  phone    String?
  address  String?
  comments String?
  total    Int // Залишаємо Int, як у вашій схемі

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  price     Int // Ціна на момент замовлення
  quantity  Int
  orderId   String   @db.ObjectId
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orderitems")
}
